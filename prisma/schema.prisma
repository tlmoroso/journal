datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output = "./generated"
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}
